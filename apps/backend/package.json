{
  "name": "@rag-chat/backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "npx tsx --env-file=.env dist/index.js",
    "type-check": "tsc --noEmit",
    "test:base": "tsx --env-file=.env src/scripts/test-base-retrieval.ts",
    "test:ensemble": "tsx --env-file=.env src/scripts/test-ensemble-retrieval.ts",
    "test:parent-child": "tsx --env-file=.env src/scripts/test-parent-child.ts",
    "test:reranker-inspect": "tsx --env-file=.env src/scripts/test-reranker-inspect.ts",
    "benchmark:rerankers": "tsx --env-file=.env src/scripts/benchmark-rerankers.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/multipart": "^8.1.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.1",
    "@langchain/anthropic": "^1.3.21",
    "@langchain/community": "^0.0.25",
    "@qdrant/js-client-rest": "^1.8.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^9.6.0",
    "cheerio": "^1.0.0-rc.12",
    "fastify": "^4.26.0",
    "langchain": "^0.1.19",
    "mammoth": "^1.6.0",
    "natural": "^8.1.0",
    "ollama": "^0.5.0",
    "pdf-parse": "^1.1.1",
    "pino-pretty": "^11.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
