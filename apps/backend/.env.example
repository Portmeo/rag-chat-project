PORT=3001
UPLOAD_DIR=./uploads

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=documents
QDRANT_VECTOR_DIMENSION=1024
QDRANT_DISTANCE_METRIC=Cosine

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDINGS_MODEL=mxbai-embed-large

# Claude Configuration (Anthropic)
# Enable Claude API for LLM generation instead of Ollama
# Claude provides better Spanish language understanding and longer context (200k tokens)
USE_CLAUDE=false
ANTHROPIC_API_KEY=your-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
# Available models:
# - claude-3-5-sonnet-20241022 (best balance of performance and cost, recommended)
# - claude-3-opus-20240229 (most capable, higher cost)
# - claude-3-haiku-20240307 (fastest, lowest cost)

# Document Processing
# Size of each text chunk in characters (1000 recommended)
CHUNK_SIZE=1000
# Overlap between chunks in characters (200 = 20% overlap)
CHUNK_OVERLAP=200

# RAG Configuration
# Enable/disable BM25 keyword-based retriever (true/false)
USE_BM25_RETRIEVER=true
# Weight for BM25 retriever when enabled (0.0 to 1.0)
# Higher value = more keyword matching, lower value = more semantic search
# RECOMENDADO: 0.5 BM25 + 0.5 Vector (equilibrio entre léxico y semántico)
# BM25 alto (0.6-0.8) causa "ruido léxico" (repite palabras sin relevancia)
BM25_WEIGHT=0.5
# Weight for vector semantic search (0.0 to 1.0)
# Must sum to 1.0 with BM25_WEIGHT
VECTOR_WEIGHT=0.5
# Maximum number of similar documents to retrieve (if reranker disabled)
SIMILARITY_SEARCH_MAX_RESULTS=4

# Reranker Configuration (Cross-Encoder for improved precision)
# Enable/disable reranking with bge-reranker-base (true/false)
# Reranking improves precision by ~10-15% but adds ~500ms-1s latency
#
# FLUJO PARENT-CHILD RAG OPTIMIZADO:
# 1. Búsqueda: Retrieve 20 children (128 chars c/u, alta granularidad)
# 2. Hydration: Resolve to unique parents (~5-8 parents de 512 chars)
# 3. Reranking: Rerank parents con contexto completo (512 tokens)
# 4. Selection: Top 3 parents (1.5k tokens total para LLM)
#
# Ventaja: Reranker evalúa contexto completo (512 tokens) en lugar de fragmentos
# Resultado: 3 bloques coherentes de 512 chars vs 8 fragmentos de 128 chars
USE_RERANKER=true
# Reranker model (Cross-Encoder from Transformers.js/Xenova)
# Options: Xenova/bge-reranker-base (default), Xenova/bge-reranker-v2-m3 (multilingual, pendiente de probar)
RERANKER_MODEL=Xenova/bge-reranker-base
# Number of child chunks to retrieve initially (20 recommended)
# These will be resolved to ~5-8 unique parent chunks
RERANKER_RETRIEVAL_TOP_K=20
# Number of top parents after reranking (3-4 recommended)
# Con 512 chars por parent: 3 parents = ~1.5k tokens para LLM
# Menos fragmentación = mejor coherencia para el LLM
RERANKER_FINAL_TOP_K=3
# Timeout for reranking operation in milliseconds (30000 = 30s)
RERANKER_TIMEOUT_MS=30000

# Embeddings Instruction Prefix Configuration
# Enable asymmetric instruction prefixes for improved retrieval (+3.7% MRR)
# Improves MRR from 0.844 to 0.875 with mxbai-embed-large
USE_INSTRUCTION_PREFIX=true
# Prefix for query embeddings (asymmetric retrieval)
# This prefix is added ONLY to queries, not to documents
EMBEDDING_QUERY_PREFIX=Represent this sentence for searching relevant passages:
# Prefix for document embeddings (empty = plain text, recommended)
# Typically empty for best asymmetric performance
EMBEDDING_DOCUMENT_PREFIX=

# Query Reformulation Configuration
# Rewrites follow-up questions into standalone queries using LLM before retrieval
# Example: "¿y en viaje?" → "¿tiene cobertura de asistencia en viaje?"
# Replaces raw history injection: improves both retrieval and generation
QUERY_REFORMULATION_ENABLED=true
# Maximum number of previous messages used for reformulation context
QUERY_REFORMULATION_MAX_MESSAGES=5

# Reranker Score Filtering
# Minimum rerank score to show sources to user (0.0 to 1.0)
# Higher = only show high-confidence sources, lower = show more sources
# RECOMENDADO: 0.6-0.7 para parent chunks (mayor contexto = mayor exigencia)
# Parents de 512 chars permiten al reranker ser más selectivo
# 0.5 es el mínimo, 0.6 es óptimo, 0.7 es muy estricto
MIN_RERANK_SCORE=0.6

# Intent Classifier Configuration
# Detects casual inputs (greetings, thanks, farewells) to skip the RAG pipeline
# Saves ~2-3s latency + tokens on casual inputs
USE_INTENT_CLASSIFIER=true
# Modes:
# - regex: Only regex patterns. Fast, no LLM cost, but misses ambiguous inputs
# - hybrid: Regex first, LLM fallback for unmatched inputs. Good balance (default)
# - llm: Everything goes through LLM. Most robust, +0.5s latency per query
INTENT_CLASSIFIER_MODE=hybrid

# Similarity Drop-off Configuration
# Instead of fixed top-K, discards docs whose score drops too far from the best result
# More intelligent: adapts to retrieval quality per query
USE_SIMILARITY_DROPOFF=true
# Maximum allowed drop from best score (0.0-1.0). 0.20 = discard if >20% worse than best
SIMILARITY_DROPOFF_MAX_DROP=0.20
# Minimum documents to always keep, regardless of drop-off
SIMILARITY_DROPOFF_MIN_DOCS=2

# Parent Document Retriever Configuration
# Enable Small-to-Big retrieval strategy for improved precision (+15-20%)
# When enabled: search with small chunks (200 chars), return large chunks (1000 chars)
# Provides best of both: precise search + rich context for LLM
USE_PARENT_RETRIEVER=true
# Child chunks: small chunks for precise vector search
CHILD_CHUNK_SIZE=200
CHILD_CHUNK_OVERLAP=50
# Parent chunks: large chunks with full context for LLM
PARENT_CHUNK_SIZE=1000
PARENT_CHUNK_OVERLAP=200
